# Environment for maludb-embedding-worker.service.
# Copy to /etc/maludb/embedding-worker.env (root-owned, chmod 0600) and fill in.

# Base URL of the running API server (no trailing slash).
MALU_API_URL=http://127.0.0.1:8000

# A tenant API token (malu_...). The worker drains THIS token's tenant queue.
# The token's user must have an `embed` model configured (POST /v1/model-prompts
# or a user model choice), or set MALUDB_EMBED_BASE_URL/_TOKEN/_MODEL on the API
# host. With neither, the endpoint returns early (deterministic vectors are not
# persisted).
MALU_TOKEN=malu_replace_me

# Max cards to embed per sweep (1-512). Optional; defaults to 64.
MALU_EMBED_LIMIT=64
