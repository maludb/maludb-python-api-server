# Environment for maludb-memory-reindex.service.
# Copy to /etc/maludb/memory-reindex.env (root-owned, chmod 0600) and fill in.

# Base URL of the running API server (no trailing slash).
MALU_API_URL=http://127.0.0.1:8000

# A tenant API token (malu_...). The sweep reindexes THIS token's tenant.
# The token's user must have an `extract` model configured (set via
# POST /v1/model-prompts or a user model choice) -- documents with no model
# are skipped.
MALU_TOKEN=malu_replace_me

# Max documents/notes to reindex per sweep (1-200). Optional; defaults to 32.
MALU_REINDEX_LIMIT=32

# Optional: restrict the sweep to one source_type (e.g. note). Empty = all.
MALU_REINDEX_SOURCE_TYPE=
